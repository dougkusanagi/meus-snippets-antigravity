{
  "name": "guepardosys-snip",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "tauri": "tauri",
    "dev": "tauri dev",
    "build": "tauri build",
    "check": "bun run check:js && bun run check:rust",
    "check:js": "bun build ./src/scripts/manager.js ./src/scripts/picker.js ./src/scripts/macro-editor.js --outdir=./.tmp-js-check --target=browser",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "format": "cargo fmt --manifest-path src-tauri/Cargo.toml"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-global-shortcut": "^2.3.2",
    "lucide": "^1.17.0"
  }
}
