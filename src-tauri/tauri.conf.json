{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "guepardosys-snip",
  "version": "0.0.1",
  "identifier": "com.guepardosys.snip",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build:web",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "guepardosys-snip",
        "width": 900,
        "height": 620,
        "minWidth": 700,
        "minHeight": 500,
        "center": true,
        "decorations": true,
        "resizable": true
      },
      {
        "label": "picker",
        "title": "",
        "url": "picker.html",
        "width": 650,
        "height": 400,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "resizable": false,
        "center": true,
        "transparent": true,
        "focus": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://api.github.com; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
